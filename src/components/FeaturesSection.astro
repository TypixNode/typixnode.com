---
import { useTranslations, type Locale } from '../i18n/ui';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);

const features = [
  { icon: '⬡', title: t('features.cnc.title'), desc: t('features.cnc.desc') },
  { icon: '⚡', title: t('features.pi.title'), desc: t('features.pi.desc') },
  { icon: '⌨', title: t('features.kbd.title'), desc: t('features.kbd.desc') },
  { icon: '🔧', title: t('features.esp.title'), desc: t('features.esp.desc') },
  { icon: '💾', title: t('features.storage.title'), desc: t('features.storage.desc') },
  { icon: '📡', title: t('features.antenna.title'), desc: t('features.antenna.desc') },
];
---
<section id="features" class="section-screen">
  <div class="max-w-6xl mx-auto px-6 py-20">
    <div class="text-center mb-16 fade-in">
      <p class="text-brand-400 font-mono text-sm tracking-widest uppercase mb-3">{t('features.tagline')}</p>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight">{t('features.title')}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="fade-in p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-brand-500/30 transition-colors">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="text-lg font-semibold mb-2">{f.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
