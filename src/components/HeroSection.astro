---
---
<section id="hero" class="section-screen relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-brand-950/20 via-gray-950 to-gray-950"></div>
  <div class="absolute inset-0 opacity-30">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-brand-500/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-72 h-72 bg-brand-400/10 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto fade-in">
    <p class="text-brand-400 font-mono text-sm tracking-widest uppercase mb-4">Compact Cyberdeck</p>
    <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-tight mb-6">
      TypixNode
    </h1>
    <p class="text-xl md:text-2xl text-gray-400 font-light max-w-2xl mx-auto mb-8">
      CNC aluminum slate cyberdeck.<br/>
      Raspberry Pi CM4/CM5. Pocketable Linux.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#features" class="px-8 py-3 rounded-full bg-brand-500 hover:bg-brand-400 text-white font-semibold transition-colors">
        Explore
      </a>
      <a href="https://github.com/TypixNode" target="_blank" rel="noopener" class="px-8 py-3 rounded-full border border-white/20 hover:border-white/40 text-white font-medium transition-colors">
        View on GitHub
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
